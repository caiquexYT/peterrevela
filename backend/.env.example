# CxIA Backend - Variáveis de Ambiente

# URL do banco de dados (para referência, não usada diretamente no backend Python)
DATABASE_URL=http://localhost:8000

# Caminho do arquivo SQLite
DATABASE_PATH=./data/cxia.db

# Porta do servidor (padrão: 8000)
PORT=8000

# Chave secreta para JWT (TROQUE EM PRODUÇÃO!)
JWT_SECRET=cxia-super-secret-key-change-in-production-2024

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173
